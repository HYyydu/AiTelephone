# Server Configuration
# Use 3001 if this is the only server. Use 4000 when another app (e.g. chat server) runs on 3001 and expects the call backend at http://localhost:4000.
PORT=3001
NODE_ENV=development
PUBLIC_URL=http://localhost:3001

# Auth: set to true to allow unauthenticated requests (POST /api/calls, etc.). Dev/testing only; do not use in production.
# ALLOW_NO_AUTH=true

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# Supabase (required for auth — set the same keys in Railway / your host’s environment)
# Project Settings → API in the Supabase dashboard
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Twilio Configuration
# Get these from: https://console.twilio.com
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890

# OpenAI Configuration
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
# Optional: OpenAI Realtime TTS voice (alloy, ash, ballad, coral, echo, sage, shimmer, verse, marin, cedar). If unset, defaults to ash via call voice_preference mapping.
# OPENAI_REALTIME_VOICE=ash

# Deepgram Configuration (for Speech-to-Text)
# Get from: https://console.deepgram.com
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# ElevenLabs Configuration (Optional - for advanced TTS)
# Get from: https://elevenlabs.io
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Google Places / Search Provider Configuration
# Get API key from: https://console.cloud.google.com/google/maps-apis
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
# Optional overrides when using a proxy or mock services
# GOOGLE_PLACES_TEXT_SEARCH_URL=https://maps.googleapis.com/maps/api/place/textsearch/json
# GOOGLE_PLACES_DETAILS_URL=https://maps.googleapis.com/maps/api/place/details/json
# GOOGLE_PLACES_RADIUS_METERS=7500
# GOOGLE_PLACES_DEFAULT_KEYWORD=clinic

# Redis Cache (optional but recommended for quota control)
# Example: redis://localhost:6379 or rediss://default:password@host:port
REDIS_URL=redis://localhost:6379
# Set to "true" if your Redis instance requires TLS (e.g., Managed services)
REDIS_TLS=false
# Cache TTL for quote search results (in seconds). Default is 12h.
PLACES_CACHE_TTL_SECONDS=43200

# Database Configuration (for later with Prisma)
DATABASE_URL=postgresql://localhost:5432/ai_customer_call

# --- OpenAI Realtime token metering (per call) ---
# Sum of input+output tokens from each `response.done` must stay below this to avoid hang-up.
# 0 = no limit (usage still tracked and emitted when the API sends usage).
# CALL_MAX_TOKENS_PER_CALL=200000
# Set to false to track usage but never end the call for budget (default: true when limit > 0).
# CALL_TOKEN_BUDGET_ENFORCE=true
# Comma-separated fractions of the limit for quota_warning Socket events (default: 0.8,0.95).
# CALL_USAGE_WARN_THRESHOLDS=0.8,0.95
# Throttle usage_update emissions (ms). Default 10000.
# CALL_USAGE_EMIT_INTERVAL_MS=10000
# How often to persist input_tokens/output_tokens on the call row (ms). Default 15000.
# CALL_USAGE_DB_FLUSH_INTERVAL_MS=15000
