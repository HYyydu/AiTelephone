# Server Configuration
# Use 3001 if this is the only server. Use 4000 when another app (e.g. chat server) runs on 3001 and expects the call backend at http://localhost:4000.
PORT=3001
NODE_ENV=development
PUBLIC_URL=http://localhost:3001

# Auth: set to true to allow unauthenticated requests (POST /api/calls, etc.). Dev/testing only; do not use in production.
# ALLOW_NO_AUTH=true

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# Twilio Configuration
# Get these from: https://console.twilio.com
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890

# OpenAI Configuration
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Deepgram Configuration (for Speech-to-Text)
# Get from: https://console.deepgram.com
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# ElevenLabs Configuration (Optional - for advanced TTS)
# Get from: https://elevenlabs.io
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Google Places / Search Provider Configuration
# Get API key from: https://console.cloud.google.com/google/maps-apis
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
# Optional overrides when using a proxy or mock services
# GOOGLE_PLACES_TEXT_SEARCH_URL=https://maps.googleapis.com/maps/api/place/textsearch/json
# GOOGLE_PLACES_DETAILS_URL=https://maps.googleapis.com/maps/api/place/details/json
# GOOGLE_PLACES_RADIUS_METERS=7500
# GOOGLE_PLACES_DEFAULT_KEYWORD=clinic

# Redis Cache (optional but recommended for quota control)
# Example: redis://localhost:6379 or rediss://default:password@host:port
REDIS_URL=redis://localhost:6379
# Set to "true" if your Redis instance requires TLS (e.g., Managed services)
REDIS_TLS=false
# Cache TTL for quote search results (in seconds). Default is 12h.
PLACES_CACHE_TTL_SECONDS=43200

# Database Configuration (for later with Prisma)
DATABASE_URL=postgresql://localhost:5432/ai_customer_call
